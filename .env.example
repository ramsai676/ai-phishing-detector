# Copy this file to ".env" and fill in your values.
# The app runs fully WITHOUT a key (offline heuristic mode); the key only
# enables AI-written, plain-English explanations.

# Your Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: override the model used for explanations.
# Cheap + fast is ideal here. Default: claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Optional: port to run the server on. Default: 3000
PORT=3000
