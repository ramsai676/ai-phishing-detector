# Copy this file to ".env". The app runs fully WITHOUT a key (heuristic mode);
# the key only enables the AI-written explanations.

# Free API key from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the model. Default: gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash

# Optional: port to run the server on. Default: 3000
PORT=3000
